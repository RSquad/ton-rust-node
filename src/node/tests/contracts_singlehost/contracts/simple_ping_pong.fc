#include "imports/stdlib.fc";

const op::start = 1;
const op::ping = 2;


global int g::last_call; 
global int g::accumulator;
global int g::salt;

() load_globals() impure {
  var ds = get_data().begin_parse();
  g::last_call = ds~load_uint(32);
  g::accumulator = ds~load_uint(32);
  g::salt = ds~load_uint(32);
  ds.end_parse();
}

() store_globals() impure {
  builder data = begin_cell()
    .store_uint(g::last_call, 32)
    .store_uint(g::accumulator, 32)
    .store_uint(g::salt, 32);
  set_data(data.end_cell());
}

() send(slice address) impure {

    cell c = begin_cell()
        .store_uint(0x18, 6)
        .store_slice(address)
        .store_coins(100000000)
        .store_uint(0, 1 + 4 + 4 + 64 + 32 + 1 + 1) ;; default message headers (see sending messages page)
        .store_uint(op::ping, 32)
        .end_cell();

    send_raw_message(c, 3);
}

() recv_external(slice in_msg_body) impure {

    load_globals();
    var new_call = in_msg_body~load_uint(32);
    if (new_call != g::last_call) {
        throw(101); 
    }
    accept_message();

    var function_id = in_msg_body~load_uint(32);
    if (function_id == 0) {
        ;; initialization
    } elseif (function_id == 1) { 
        ;; start
        slice second_contract_address = in_msg_body~load_msg_addr();
        var n = in_msg_body~load_uint(8);
        while (n > 0) {
            send(second_contract_address);
            n -= 1;
        }
    }

    g::last_call += 1;
    store_globals();
}

() recv_internal(int msg_value, cell in_msg_full, slice in_msg_body) impure {
    if (in_msg_body.slice_empty?()) { ;; ignore all empty messages
        return ();
    }

    slice cs = in_msg_full.begin_parse();
    int flags = cs~load_uint(4);
    if (flags & 1) { ;; ignore all bounced messages
        return ();
    }

    load_globals();

    ;; by convention, the first 32 bits of incoming message is the op
    int op = in_msg_body~load_uint(32); 

    if (op == op::start) {
        g::accumulator = 0;
        slice addr = in_msg_body~load_msg_addr();
        var n = in_msg_body~load_uint(8);
        while (n > 0) {
            send(addr);
            n -= 1;
        }
    }
    if (op == op::ping) {   
        g::accumulator += 1;
        slice addr = cs~load_msg_addr();
        send(addr);
    }

    store_globals();
}

int get_accumulator() method_id {
    load_globals();
    return g::accumulator;
}
